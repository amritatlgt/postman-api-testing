              "var jsonData = pm.response.json();",
              "",
              "",
              "pm.test(\"Products array exists\", function () {",
              "    pm.expect(jsonData.products).to.be.an(\"array\");",
              "});",
              "",
              "pm.test(\"Products array is not empty\", function () {",
              "    pm.expect(jsonData.products.length).to.be.above(0);",
              "});",
              "",
              "pm.test(\"Total products should be 194\", function () {",
              "    pm.expect(jsonData.total).to.eql(194);",

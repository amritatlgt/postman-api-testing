    {
      "name": "Step - 13 Response Validation",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status Code should be 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "var jsonData = pm.response.json();",
              "",
              "pm.test(\"Product ID should be 1\", function () {",
              "    pm.expect(jsonData.id).to.eql(1);",
              "});",
              "",
              "pm.test(\"Title should exist\", function () {",
              "    pm.expect(jsonData.title).to.exist;",
              "});",
              "",
              "pm.test(\"Category should exist\", function () {",
              "    pm.expect(jsonData.category).to.exist;",
              "});",
              "",
              "pm.test(\"Price should exist\", function () {",
              "    pm.expect(jsonData.price).to.exist;",
              "});",
              "",
              "pm.test(\"Title should be string\", function () {",
              "    pm.expect(jsonData.title).to.be.a(\"string\");",
              "});",
              "",
              "pm.test(\"Price should be number\", function () {",
              "    pm.expect(jsonData.price).to.be.a(\"number\");",
              "});",
              "",
              "pm.test(\"Tags should be array\", function () {",
              "    pm.expect(jsonData.tags).to.be.an(\"array\");",
              "});",
              "",
              "pm.test(\"Dimensions should be object\", function () {",
              "    pm.expect(jsonData.dimensions).to.be.an(\"object\");",
              "});",
              "",
              "pm.test(\"Tags should contain at least one value\", function () {",
              "    pm.expect(jsonData.tags.length).to.be.above(0);",
              "});",
              "",
              "pm.test(\"Price should be greater than 0\", function () {",
              "    pm.expect(jsonData.price).to.be.above(0);",
              "});",
              "",
              "pm.test(\"Stock should be greater than 0\", function () {",
              "    pm.expect(jsonData.stock).to.be.above(0);",
              "});",
              "",
              "pm.test(\"Rating should be between 0 and 5\", function () {",
              "    pm.expect(jsonData.rating).to.be.within(0,5);",
              "});",
              "",
              "pm.test(\"Width should be number\", function () {",
              "    pm.expect(jsonData.dimensions.width).to.be.a(\"number\");",
              "});",
              "",
              "pm.test(\"Height should be number\", function () {",
              "    pm.expect(jsonData.dimensions.height).to.be.a(\"number\");",
              "});",
              "",
              "pm.test(\"Depth should be number\", function () {",
              "    pm.expect(jsonData.dimensions.depth).to.be.a(\"number\");",
              "});",
              "",
              "pm.test(\"Title should not be empty\", function () {",
              "    pm.expect(jsonData.title).to.not.be.empty;",
              "});",
              "",
              "pm.test(\"First tag should exist\", function () {",
              "    pm.expect(jsonData.tags[0]).to.exist;",
              "});",
              "",
              "pm.test(\"Response time should be less than 1000 ms\", function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(1000);",
              "});",
              "",
              "pm.test(\"Content-Type should be application/json\", function () {",
              "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\");",
              "});",
              "",
              "pm.test(\"Response size should be less than 5 KB\", function () {",
              "    pm.expect(pm.response.responseSize).to.be.below(5000);",
              "});",
              "",
              "pm.test(\"Discount should not be negative\", function () {",
              "    pm.expect(jsonData.discountPercentage).to.be.at.least(0);",
              "});",
              "",
              "pm.test(\"Stock should not be negative\", function () {",
              "    pm.expect(jsonData.stock).to.be.at.least(0);",
              "});",
              "",
